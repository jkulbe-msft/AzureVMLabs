{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "13275409875572905716"
    },
    "description": "Deploys the virtual network infrastructure used by the AzureVMLabs demo environment. Two subnets are defined: NAT (for the Hyper-V host) and Azure-VMs (for the Domain Controller and any other Azure-hosted VMs). Nested VMs sit behind the Hyper-V host on an internal Hyper-V switch and reach the network through host-side NAT, so no Azure subnet is required for them."
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "northeurope",
      "metadata": {
        "description": "Location for all network resources."
      }
    },
    "virtualNetworkName": {
      "type": "string",
      "defaultValue": "VirtualNetwork",
      "metadata": {
        "description": "Name of the virtual network."
      }
    },
    "virtualNetworkAddressPrefix": {
      "type": "string",
      "defaultValue": "10.0.0.0/22",
      "metadata": {
        "description": "Virtual network address space. Wide enough to accommodate future subnets without redeploying."
      }
    },
    "natSubnetName": {
      "type": "string",
      "defaultValue": "NAT",
      "metadata": {
        "description": "Name of the NAT subnet (used by the Hyper-V host NIC)."
      }
    },
    "natSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.0.0.0/24",
      "metadata": {
        "description": "Address prefix of the NAT subnet."
      }
    },
    "azureVMsSubnetName": {
      "type": "string",
      "defaultValue": "Azure-VMs",
      "metadata": {
        "description": "Name of the subnet for Azure-hosted VMs such as the Domain Controller."
      }
    },
    "azureVMsSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.0.3.0/24",
      "metadata": {
        "description": "Address prefix of the Azure-VMs subnet."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-05-01",
      "name": "[format('{0}NSG', parameters('natSubnetName'))]",
      "location": "[parameters('location')]",
      "properties": {}
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-05-01",
      "name": "[format('{0}NSG', parameters('azureVMsSubnetName'))]",
      "location": "[parameters('location')]",
      "properties": {}
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2024-05-01",
      "name": "[parameters('virtualNetworkName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('virtualNetworkAddressPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "[parameters('natSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('natSubnetPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', format('{0}NSG', parameters('natSubnetName')))]"
              }
            }
          },
          {
            "name": "[parameters('azureVMsSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('azureVMsSubnetPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', format('{0}NSG', parameters('azureVMsSubnetName')))]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', format('{0}NSG', parameters('azureVMsSubnetName')))]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', format('{0}NSG', parameters('natSubnetName')))]"
      ]
    }
  ],
  "outputs": {
    "virtualNetworkName": {
      "type": "string",
      "value": "[parameters('virtualNetworkName')]"
    },
    "virtualNetworkId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', parameters('virtualNetworkName'))]"
    },
    "natSubnetName": {
      "type": "string",
      "value": "[parameters('natSubnetName')]"
    },
    "azureVMsSubnetName": {
      "type": "string",
      "value": "[parameters('azureVMsSubnetName')]"
    },
    "virtualNetworkAddressPrefix": {
      "type": "string",
      "value": "[parameters('virtualNetworkAddressPrefix')]"
    }
  }
